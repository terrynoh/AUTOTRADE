# ── 한국투자증권 KIS Open API ──────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                        # 실매매 계좌번호 (10자리)
KIS_HTS_ID=                            # HTS ID (R15-005 체결통보 구독용 tr_key). 운영: chmod 600 .env

# ── 대시보드 ───────────────────────────────────────────────
DASHBOARD_PORT=8503                    # 기본 8503 (Cloudflare Named Tunnel app.hwrimlab.trade 연결)
DASHBOARD_ADMIN_TOKEN=                 # 제어 버튼 사용 토큰 (빈값이면 제한 없음)

# ── 로컬 동기화 스크립트 전용 (운영 서버에서는 불필요) ───────
DASHBOARD_URL=                         # scripts/sync_trades.py 용 원격 API 엔드포인트 (예: https://app.hwrimlab.trade)

# ── 텔레그램 ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 로깅 ──────────────────────────────────────────────────
LOG_LEVEL=DEBUG
