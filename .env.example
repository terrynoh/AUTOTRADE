# ── 한국투자증권 KIS Open API ──────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                        # 실매매 계좌번호 (10자리)
KIS_ACCOUNT_NO_PAPER=                  # 모의투자 계좌번호 (10자리)

# ── 매매 모드 ──────────────────────────────────────────────
# dry_run : 주문 없이 시그널 로깅 + 가상 P&L
# paper   : KIS 모의투자 계좌 실제 주문
# live    : 실매매 (충분한 검증 후!)
TRADE_MODE=dry_run

# ── 대시보드 ───────────────────────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_ADMIN_TOKEN=                 # 제어 버튼 사용 토큰 (빈값이면 제한 없음)

# ── 텔레그램 ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 로깅 ──────────────────────────────────────────────────
LOG_LEVEL=DEBUG
